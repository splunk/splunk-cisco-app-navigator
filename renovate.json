  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "mergeConfidence:all-badges"
  ],
  "labels": [
    "dependency-update"
  ],
  "major": {
    "labels": [
      "major",
      "dependency-update"
    ]
  },
  "minor": {
    "labels": [
